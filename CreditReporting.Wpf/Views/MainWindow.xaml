<Window x:Class="CreditReporting.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CreditReporting.Wpf.Views"
        Title="Credit Reporting System (Demo)"
        Height="760" Width="1180"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1F3864" Padding="14,10">
            <DockPanel LastChildFill="False" Margin="0,0,-4,0">
                <TextBlock Text="Credit Reporting System" DockPanel.Dock="Left"
                           Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Name="SettingsButton" DockPanel.Dock="Right" MinWidth="0" Width="25" FontFamily="Segoe Fluent Icons" FontSize="12" Content="&#xE713;" ToolTip="Settings" Foreground="White" Background="Transparent" BorderBrush="Transparent" Padding="0" Click="SettingsButton_Click"/>
                <TextBlock DockPanel.Dock="Right" Margin="0,0,10,0"
                           Foreground="#CFE0FF" VerticalAlignment="Center">
                    <Run Text="Signed in as " /><Run Text="{Binding CurrentUser, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
            </DockPanel>
        </Border>

        <TabControl Name="MainTabControl" SelectedIndex="{Binding SelectedTabIndex}" Margin="8">
            <TabItem Header="Customer Search">
                <views:CustomerSearchView DataContext="{Binding Search}" />
            </TabItem>
            <TabItem Header="Credit Report">
                <views:CreditReportView DataContext="{Binding Report}" />
            </TabItem>
            <TabItem Header="Metro 2 Export"
                     Visibility="{Binding Metro2ExportVisible, Converter={StaticResource BoolToVis}}">
                <views:Metro2ExportView DataContext="{Binding Export}" />
            </TabItem>
            <TabItem Header="Metro 2 Import / Preview"
                     Visibility="{Binding Metro2ImportVisible, Converter={StaticResource BoolToVis}}">
                <views:Metro2ImportView DataContext="{Binding Import}" />
            </TabItem>
            <TabItem Name="SettingsView" Header="Settings" LostFocus="SettingsView_LostFocus">
                <views:SettingsView DataContext="{Binding Settings}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

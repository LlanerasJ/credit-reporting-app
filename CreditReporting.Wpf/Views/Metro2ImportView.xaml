<UserControl x:Class="CreditReporting.Wpf.Views.Metro2ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CreditReporting.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:Metro2ImportViewModel}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Load Metro 2 File…"
                    Command="{Binding BrowseAndParseCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            <TextBlock Text="{Binding LoadedFile}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Style="{StaticResource StatusText}" />

        <Border Grid.Row="2" Background="#EEF3FB" CornerRadius="4" Padding="10" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock>
                    <Run Text="Reporter: " FontWeight="SemiBold" /><Run Text="{Binding Header.ReporterName, Mode=OneWay}" />
                    <Run Text="    Cycle: " FontWeight="SemiBold" /><Run Text="{Binding Header.CycleIdentifier, Mode=OneWay}" />
                    <Run Text="    Activity Date: " FontWeight="SemiBold" /><Run Text="{Binding Header.ActivityDate, Mode=OneWay, StringFormat=d}" />
                    <Run Text="    Trailer Totals: Base " FontWeight="SemiBold" /><Run Text="{Binding Trailer.TotalBaseRecords, Mode=OneWay}" />
                    <Run Text="  J1: " FontWeight="SemiBold" /><Run Text="{Binding Trailer.TotalJ1Segments, Mode=OneWay}" />
                    <Run Text="  K1: " FontWeight="SemiBold" /><Run Text="{Binding Trailer.TotalK1Segments, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="3">
            <TextBlock DockPanel.Dock="Top" Text="Parsed Records" Style="{StaticResource SectionHeader}" />
            <DataGrid ItemsSource="{Binding Records}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding RecordNumber}" Width="Auto" />
                    <DataGridTextColumn Header="Account #" Binding="{Binding ConsumerAccountNumber}" Width="Auto" />
                    <DataGridTextColumn Header="Surname" Binding="{Binding Surname}" Width="*" />
                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*" />
                    <DataGridTextColumn Header="SSN" Binding="{Binding SsnMasked}" Width="Auto" />
                    <DataGridTextColumn Header="Portfolio" Binding="{Binding PortfolioType}" Width="Auto" />
                    <DataGridTextColumn Header="Type" Binding="{Binding AccountType}" Width="Auto" />
                    <DataGridTextColumn Header="Status" Binding="{Binding AccountStatus}" Width="Auto" />
                    <DataGridTextColumn Header="Rating" Binding="{Binding PaymentRating}" Width="Auto" />
                    <DataGridTextColumn Header="Opened" Binding="{Binding DateOpened, StringFormat=d}" Width="Auto" />
                    <DataGridTextColumn Header="Limit" Binding="{Binding CreditLimit, StringFormat=N0}" Width="Auto" />
                    <DataGridTextColumn Header="Balance" Binding="{Binding CurrentBalance, StringFormat=N0}" Width="Auto" />
                    <DataGridTextColumn Header="Past Due" Binding="{Binding AmountPastDue, StringFormat=N0}" Width="Auto" />
                    <DataGridTextColumn Header="History" Binding="{Binding PaymentHistoryProfile}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Original Creditor (K1)" Binding="{Binding OriginalCreditor}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <TextBlock Grid.Row="4" Text="Validation Issues" Style="{StaticResource SectionHeader}" />
        <DataGrid Grid.Row="5" ItemsSource="{Binding Issues}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Record #" Binding="{Binding RecordNumber}" Width="Auto" />
                <DataGridTextColumn Header="Account" Binding="{Binding AccountNumberMasked}" Width="Auto" />
                <DataGridTextColumn Header="Field" Binding="{Binding FieldName}" Width="Auto" />
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="Auto" />
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
